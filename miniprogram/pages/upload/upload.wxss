.container { padding: 24rpx; padding-bottom: 48rpx; }

.header-card { background: linear-gradient(135deg, #0f3460, #e94560); padding: 40rpx 32rpx; border-radius: 20rpx; color: #fff; margin-bottom: 24rpx; }
.header-title { font-size: 38rpx; font-weight: 800; }
.header-desc { font-size: 24rpx; opacity: 0.7; margin-top: 8rpx; }

.input-card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; }
.input-label { font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; }
.input-field { width: 100%; padding: 20rpx; border: 2rpx solid #eee; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; }

.upload-btn { padding: 28rpx; color: #fff; border-radius: 16rpx; font-size: 26rpx; font-weight: 500; text-align: center; background: #e94560; }
.upload-hint { text-align: center; font-size: 24rpx; color: #999; margin-top: 12rpx; }

.success-card { background: #e8f5e9; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; }
.success-title { font-size: 32rpx; font-weight: bold; color: #2e7d32; }
.success-info { font-size: 26rpx; color: #555; margin-top: 12rpx; line-height: 1.8; }

.error-card { background: #ffebee; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; color: #c62828; }

.section-title { font-size: 32rpx; font-weight: bold; margin: 28rpx 0 16rpx; }

.bank-card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.bank-name { font-size: 30rpx; font-weight: bold; color: #333; }
.bank-count { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.bank-arrow { font-size: 24rpx; color: #0f3460; }

.empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 28rpx; }