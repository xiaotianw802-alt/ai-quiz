.container { padding: 24rpx; padding-bottom: 48rpx; }

.progress-bar { height: 6rpx; background: #e0e0e0; border-radius: 3rpx; margin-bottom: 24rpx; }
.progress-fill { height: 100%; background: #c62828; border-radius: 3rpx; }

.q-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.q-number { font-size: 26rpx; color: #999; }
.wrong-badge { display: inline-block; padding: 4rpx 16rpx; background: #ffebee; color: #c62828; border-radius: 8rpx; font-size: 22rpx; }

.q-content { font-size: 32rpx; font-weight: 600; line-height: 1.7; color: #222; }

.option-item { padding: 26rpx 28rpx; margin-bottom: 14rpx; background: #fff; border-radius: 14rpx; border: 2rpx solid #eee; font-size: 30rpx; }

.answer-box { margin-top: 20rpx; padding: 26rpx; background: #f0f7ff; border-radius: 14rpx; border: 1rpx solid #d0e3f7; }
.answer-label { font-weight: bold; color: #e94560; font-size: 26rpx; }
.answer-text { font-size: 28rpx; color: #333; margin-top: 8rpx; }
.answer-analysis { font-size: 24rpx; color: #888; margin-top: 12rpx; line-height: 1.6; }

.q-nav { display: flex; justify-content: space-between; margin-top: 36rpx; gap: 20rpx; }
.nav-btn { flex: 1; text-align: center; padding: 22rpx; border-radius: 14rpx; font-size: 28rpx; font-weight: 500; }
.nav-btn-prev { background: #f0f0f0; color: #666; }
.nav-btn-next { background: #e94560; color: #fff; }

.toggle-btn { display: inline-block; padding: 12rpx 28rpx; background: #0f3460; color: #fff; border-radius: 20rpx; font-size: 24rpx; }

.loading { text-align: center; padding: 160rpx 0; color: #999; font-size: 28rpx; }
.empty-box { text-align: center; padding: 120rpx 40rpx; }
.empty-emoji { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #333; font-weight: bold; }